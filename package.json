{
  "name": "anaboard",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:doctor": "bash ./scripts/android-local-build.sh doctor",
    "android:prebuild": "bash ./scripts/android-local-build.sh prebuild",
    "android:apk": "bash ./scripts/android-local-build.sh apk",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "migrations:test": "node --experimental-strip-types scripts/test-db-migrations.mjs",
    "functions:check": "deno check --config supabase/functions/deno.json supabase/functions/ai-emoji-suggest/index.ts supabase/functions/ai-autocomplete-rerank/index.ts supabase/functions/ai-image-draft-generate/index.ts supabase/functions/ai-image-draft-promote/index.ts",
    "functions:env": "bash ./scripts/supabase-functions.sh check-env",
    "functions:serve": "bash ./scripts/supabase-functions.sh serve",
    "functions:secrets": "bash ./scripts/supabase-functions.sh set-secrets",
    "functions:deploy": "bash ./scripts/supabase-functions.sh deploy"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.97.0",
    "expo": "~54.0.33",
    "expo-application": "~7.0.8",
    "expo-audio": "~1.1.1",
    "expo-crypto": "~15.0.8",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-network": "~8.0.8",
    "expo-speech": "~14.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "^0.21.0",
    "rn-emoji-keyboard": "^1.7.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
